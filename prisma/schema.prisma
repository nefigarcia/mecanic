generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANT ────────────────────────────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique
  nombre       String
  logo         String?
  telefono     String?
  email        String?
  direccion    String?
  ciudad       String?
  estado       String?
  codigoPostal String?
  rfc          String?
  plan         Plan     @default(BASICO)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usuarios   TenantUsuario[]
  clientes   Cliente[]
  vehiculos  Vehiculo[]
  ordenes    OrdenTrabajo[]
  servicios  Servicio[]
  partes     Parte[]
  citas      Cita[]
  facturas   Factura[]
  empleados  Empleado[]
  categorias Categoria[]
}

enum Plan {
  BASICO
  PROFESIONAL
  EMPRESARIAL
}

// ─── USUARIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id            String    @id @default(cuid())
  nombre        String
  email         String    @unique
  emailVerified DateTime?
  imagen        String?
  password      String?
  rol           RolGlobal @default(USUARIO)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenants  TenantUsuario[]
  cuentas  Cuenta[]
  sesiones Sesion[]
}

enum RolGlobal {
  SUPER_ADMIN
  USUARIO
}

model TenantUsuario {
  id        String    @id @default(cuid())
  tenantId  String
  usuarioId String
  rol       RolTenant @default(EMPLEADO)
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usuarioId])
}

enum RolTenant {
  ADMINISTRADOR
  GERENTE
  MECANICO
  RECEPCIONISTA
  EMPLEADO
}

// NextAuth models
model Cuenta {
  id                String  @id @default(cuid())
  usuarioId         String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Sesion {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  usuarioId    String
  expires      DateTime
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model TokenVerificacion {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────

model Cliente {
  id        String   @id @default(cuid())
  tenantId  String
  nombre    String
  apellido  String
  email     String?
  telefono  String
  celular   String?
  direccion String?
  ciudad    String?
  notas     String?  @db.Text
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehiculos Vehiculo[]
  ordenes   OrdenTrabajo[]
  facturas  Factura[]
  citas     Cita[]
}

// ─── VEHÍCULOS ────────────────────────────────────────────────────────────────

model Vehiculo {
  id          String   @id @default(cuid())
  tenantId    String
  clienteId   String
  marca       String
  modelo      String
  anio        Int
  color       String?
  placa       String?
  vin         String?
  kilometraje Int?
  notas       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente   Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordenes   OrdenTrabajo[]
  citas     Cita[]
}

// ─── EMPLEADOS ────────────────────────────────────────────────────────────────

model Empleado {
  id           String   @id @default(cuid())
  tenantId     String
  nombre       String
  apellido     String
  email        String?
  telefono     String?
  puesto       String?
  especialidad String?
  activo       Boolean  @default(true)
  color        String   @default("#6366f1")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ordenes OrdenTrabajo[]
  citas   Cita[]
}

// ─── CATEGORÍAS ───────────────────────────────────────────────────────────────

model Categoria {
  id        String        @id @default(cuid())
  tenantId  String
  nombre    String
  tipo      TipoCategoria
  createdAt DateTime      @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  servicios Servicio[]
  partes    Parte[]
}

enum TipoCategoria {
  SERVICIO
  PARTE
}

// ─── SERVICIOS ────────────────────────────────────────────────────────────────

model Servicio {
  id          String   @id @default(cuid())
  tenantId    String
  categoriaId String?
  nombre      String
  descripcion String?  @db.Text
  precio      Decimal  @db.Decimal(10, 2)
  duracion    Int?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  items     ItemOrden[]
}

// ─── PARTES/INVENTARIO ────────────────────────────────────────────────────────

model Parte {
  id          String   @id @default(cuid())
  tenantId    String
  categoriaId String?
  nombre      String
  descripcion String?
  sku         String?
  marca       String?
  precio      Decimal  @db.Decimal(10, 2)
  costo       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  stockMinimo Int      @default(5)
  unidad      String   @default("pza")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  items     ItemOrden[]

  @@unique([tenantId, sku])
}

// ─── ÓRDENES DE TRABAJO ───────────────────────────────────────────────────────

model OrdenTrabajo {
  id           String      @id @default(cuid())
  tenantId     String
  clienteId    String
  vehiculoId   String
  empleadoId   String?
  numero       Int
  estado       EstadoOrden @default(RECIBIDO)
  prioridad    Prioridad   @default(NORMAL)
  descripcion  String?     @db.Text
  diagnostico  String?     @db.Text
  notas        String?     @db.Text
  promesa      DateTime?
  kilometraje  Int?
  subtotal     Decimal     @db.Decimal(10, 2) @default(0)
  descuento    Decimal     @db.Decimal(10, 2) @default(0)
  impuesto     Decimal     @db.Decimal(10, 2) @default(0)
  total        Decimal     @db.Decimal(10, 2) @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  completadoAt DateTime?

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente  Cliente    @relation(fields: [clienteId], references: [id])
  vehiculo Vehiculo   @relation(fields: [vehiculoId], references: [id])
  empleado Empleado?  @relation(fields: [empleadoId], references: [id])
  items    ItemOrden[]
  factura  Factura?

  @@unique([tenantId, numero])
}

enum EstadoOrden {
  RECIBIDO
  DIAGNOSTICO
  APROBADO
  EN_PROCESO
  EN_ESPERA
  LISTO
  ENTREGADO
  CANCELADO
}

enum Prioridad {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

model ItemOrden {
  id          String   @id @default(cuid())
  ordenId     String
  tipo        TipoItem
  servicioId  String?
  parteId     String?
  descripcion String
  cantidad    Decimal  @db.Decimal(10, 2) @default(1)
  precioUnit  Decimal  @db.Decimal(10, 2)
  descuento   Decimal  @db.Decimal(10, 2) @default(0)
  subtotal    Decimal  @db.Decimal(10, 2)

  orden    OrdenTrabajo @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  servicio Servicio?    @relation(fields: [servicioId], references: [id])
  parte    Parte?       @relation(fields: [parteId], references: [id])
}

enum TipoItem {
  SERVICIO
  PARTE
  OTRO
}

// ─── CITAS ────────────────────────────────────────────────────────────────────

model Cita {
  id          String     @id @default(cuid())
  tenantId    String
  clienteId   String
  vehiculoId  String
  empleadoId  String?
  titulo      String
  descripcion String?    @db.Text
  inicio      DateTime
  fin         DateTime
  estado      EstadoCita @default(PENDIENTE)
  notas       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente   Cliente   @relation(fields: [clienteId], references: [id])
  vehiculo  Vehiculo  @relation(fields: [vehiculoId], references: [id])
  empleado  Empleado? @relation(fields: [empleadoId], references: [id])
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  EN_PROCESO
  COMPLETADA
  CANCELADA
  NO_SHOW
}

// ─── FACTURAS ─────────────────────────────────────────────────────────────────

model Factura {
  id          String        @id @default(cuid())
  tenantId    String
  clienteId   String
  ordenId     String?       @unique
  numero      String
  estado      EstadoFactura @default(PENDIENTE)
  subtotal    Decimal       @db.Decimal(10, 2)
  impuesto    Decimal       @db.Decimal(10, 2)
  descuento   Decimal       @db.Decimal(10, 2) @default(0)
  total       Decimal       @db.Decimal(10, 2)
  metodoPago  MetodoPago?
  pagadoAt    DateTime?
  vencimiento DateTime?
  notas       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente Cliente       @relation(fields: [clienteId], references: [id])
  orden   OrdenTrabajo? @relation(fields: [ordenId], references: [id])
}

enum EstadoFactura {
  BORRADOR
  PENDIENTE
  PAGADA
  VENCIDA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  TARJETA_CREDITO
  TARJETA_DEBITO
  TRANSFERENCIA
  CHEQUE
  OTRO
}
